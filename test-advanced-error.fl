// Advanced error handling tests

// Test 1: Nested try-catch
println("Test 1: Nested try-catch");
try {
  try {
    throw "inner error";
  } catch (inner_e) {
    println("Inner catch:");
    println(inner_e);
    throw "outer error";
  }
} catch (outer_e) {
  println("Outer catch:");
  println(outer_e);
}

// Test 2: Error with Result type
println("\nTest 2: Error wrapping");
try {
  let result = Err("something went wrong");
  match result {
    Err(e) => throw e,
    Ok(v) => println(v),
  }
} catch (e) {
  println("Caught error from Result:");
  println(e);
}

// Test 3: Multiple catches
println("\nTest 3: Multiple try blocks");
try {
  println("Try block 1");
  throw "Error 1";
} catch (e1) {
  println("Catch 1:");
  println(e1);
}

try {
  println("Try block 2");
  let val = 42;
} catch (e2) {
  println("This should not print");
}

println("\n✅ Advanced tests completed!");
