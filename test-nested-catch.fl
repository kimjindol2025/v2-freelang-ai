// Test 1: Nested try-catch
println("Test 1: Nested try-catch");
try {
  try {
    throw "inner error";
  } catch (inner_e) {
    println("Inner catch:");
    println(inner_e);
    throw "outer error";
  }
} catch (outer_e) {
  println("Outer catch:");
  println(outer_e);
}

// Test 2: Multiple sequential try blocks
println("\nTest 2: Multiple try blocks");
try {
  println("Try block 1");
  throw "Error 1";
} catch (e1) {
  println("Catch 1:");
  println(e1);
}

try {
  println("Try block 2");
  let val = 42;
} catch (e2) {
  println("This should not print");
}

println("\n✅ Tests completed!");
