// Test map: double each element
let arr = [1, 2, 3];
let double = fn(x) { x * 2 };
let doubled = arr.map(double);
println(doubled);

// Test filter: keep even numbers
let isEven = fn(x) { x % 2 == 0 };
let nums = [1, 2, 3, 4, 5, 6];
let evens = nums.filter(isEven);
println(evens);

// Test reduce: sum all elements
let sum = fn(acc, x) { acc + x };
let numbers = [1, 2, 3, 4, 5];
let total = numbers.reduce(sum, 0);
println(total);
