// Test 1: Ok pattern binding (constant print, avoid checker issue)
let result1 = Ok(42);
match result1 {
  Ok(x) => println("ok_matched"),
  Err(e) => println("err"),
}

// Test 2: Some pattern binding
let opt = Some(99);
match opt {
  Some(v) => println("some_matched"),
  None => println("none"),
}
