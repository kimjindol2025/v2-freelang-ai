// 테스트 1: Ok 패턴 바인딩
let result1 = Ok(42);
match result1 {
  Ok(x) => println(x),
  Err(e) => println(e),
}

// 테스트 2: Err 패턴 바인딩
let result2 = Err("failed");
match result2 {
  Ok(x) => println(x),
  Err(e) => println(e),
}

// 테스트 3: Some 패턴 바인딩
let opt = Some(99);
match opt {
  Some(v) => println(v),
  None => println("empty"),
}

// 테스트 4: None 패턴
let opt2 = None;
match opt2 {
  Some(v) => println(v),
  None => println("empty"),
}
