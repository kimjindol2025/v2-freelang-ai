// Test 1: Simple throw and catch
println("Test 1: Simple throw and catch");
try {
  throw "error message";
} catch (e) {
  println("Caught:");
  println(e);
}

// Test 2: Throw in conditional
println("\nTest 2: Throw in conditional");
let x = 5;
try {
  if (x > 3) {
    throw "x is too big!";
  }
  println("No error");
} catch (err) {
  println("Error caught:");
  println(err);
}

// Test 3: Normal execution without error
println("\nTest 3: No error case");
try {
  println("In try block");
  let y = 10;
} catch (e) {
  println("This should not print");
}
println("After try block");

println("\n✅ All tests completed!");
