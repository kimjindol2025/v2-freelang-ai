// ============================================================
// Task 3: Higher-Order Functions Test
// ============================================================

// Test 1: map() - Transform each element
println("Test 1: map()");
let numbers = [1, 2, 3];
let doubled = numbers.map(fn(x) { x * 2 });
println(doubled);

// Test 2: filter() - Keep elements matching condition
println("Test 2: filter()");
let nums = [1, 2, 3, 4, 5, 6];
let evens = nums.filter(fn(x) { x % 2 == 0 });
println(evens);

// Test 3: reduce() - Accumulate values
println("Test 3: reduce()");
let arr = [1, 2, 3, 4, 5];
let sum = arr.reduce(fn(acc, x) { acc + x }, 0);
println(sum);

// Test 4: Chaining map operations
println("Test 4: Chaining");
let result = [1, 2, 3].map(fn(x) { x * 2 }).map(fn(y) { y + 1 });
println(result);

// Test 5: Using closures in nested contexts
println("Test 5: Complex operations");
let data = [1, 2, 3, 4, 5];
let processed = data
  .filter(fn(x) { x > 2 })
  .map(fn(x) { x * 3 });
println(processed);

println("✅ All tests completed!");
