struct Token {
  type: string,
  lexeme: string,
  line: i32
}

fn get_len(s: string) -> i32 {
  return length(s)
}

fn tokenizeSimple(source: string) -> string {
  var result: string = "["
  var pos: i32 = 0
  var len: i32 = length(source)

  while pos < len {
    var x: i32 = get_len(source)
    pos = pos + 1
  }

  return result
}

fn main(): void {
  var x: string = tokenizeSimple("test")
  println(x)
}
