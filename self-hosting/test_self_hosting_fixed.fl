// 자체 호스팅 테스트: v2가 자신을 컴파일할 수 있는가?

// 글로벌 함수들
fn add(a: i32, b: i32) -> i32 {
  return a + b
}

fn test_basic_arithmetic() -> void {
  var x: i32 = 10
  var y: i32 = 20
  var result: i32 = x + y
  println("Test 1 - Basic arithmetic: " + str(result))
}

fn test_function_call() -> void {
  var result: i32 = add(5, 7)
  println("Test 2 - Function call: " + str(result))
}

fn test_while_loop() -> void {
  var i: i32 = 0
  var sum: i32 = 0

  while i < 5 {
    sum = sum + i
    i = i + 1
  }

  println("Test 3 - While loop sum: " + str(sum))
}

fn test_if_statement() -> void {
  var x: i32 = 10

  if x > 5 {
    println("Test 4 - If statement: TRUE")
  }
}

fn test_array_operations() -> void {
  var arr: any = []
  push(arr, 1)
  push(arr, 2)
  push(arr, 3)

  println("Test 5 - Array length: " + str(length(arr)))
}

fn test_break_continue() -> void {
  var i: i32 = 0
  var count: i32 = 0

  while i < 10 {
    i = i + 1

    if i == 3 {
      continue
    }

    if i == 7 {
      break
    }

    count = count + 1
  }

  println("Test 6 - Break/Continue count: " + str(count))
}

fn test_struct_basic() -> void {
  var data: any = {name: "test", value: 42}
  println("Test 7 - Struct creation: OK")
}

fn main(): void {
  println("=====================================")
  println("  FreeLang v2 Self-Hosting Test")
  println("=====================================")
  println("")

  test_basic_arithmetic()
  test_function_call()
  test_while_loop()
  test_if_statement()
  test_array_operations()
  test_break_continue()
  test_struct_basic()

  println("")
  println("✅ Self-Hosting Tests Complete")
  println("=====================================")
}
