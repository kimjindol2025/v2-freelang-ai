struct Token {
  type: string,
  lexeme: string,
  line: i32
}

fn tokenizeSimple(source: string) -> string {
  var result: string = "["
  var pos: i32 = 0

  while pos < 3 {
    result = result + "x"
    pos = pos + 1
  }

  return result
}

fn main(): void {
  var output: string = tokenizeSimple("test")
  println(output)
}
