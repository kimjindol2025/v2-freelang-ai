{
  "name": "freelang",
  "version": "2.9.0",
  "description": "FreeLang v2.9.0 - Zero-Dependency AI Compiler (Native-Guard Hook Complete)",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "scripts": {
    "build": "node build.js && tsc",
    "build:ts": "tsc",
    "build:fl": "node build.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:stage1": "ts-node test-freelang-complete.ts",
    "compile": "tsc src/compiler/compiler.ts src/compiler/isa-generator.ts src/vm/vm-executor.ts test-freelang-complete.ts --outDir dist --target es2020 --module commonjs",
    "lint": "eslint src --ext .ts",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "clean": "rm -rf dist",
    "lsp": "node dist/lsp/server.js",
    "lsp:dev": "ts-node src/lsp/server.ts"
  },
  "keywords": [
    "ai",
    "programming-language",
    "code-generation",
    "c-backend",
    "minimal-intent",
    "freelang"
  ],
  "author": "Claude AI",
  "license": "MIT",
  "bin": {
    "freelang": "bin/freelang"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chalk": "^4.1.2",
    "express": "^5.2.1",
    "koffi": "^2.15.1",
    "spdy": "^4.0.2",
    "vscode-languageserver": "^8.1.0",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://gogs.dclub.kr/kim/v2-freelang-ai.git"
  },
  "bugs": {
    "url": "https://gogs.dclub.kr/kim/v2-freelang-ai/issues"
  },
  "homepage": "https://gogs.dclub.kr/kim/v2-freelang-ai",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "KNOWN_ISSUES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "kpm": {
    "category": "language-runtime",
    "subcategory": "official-language",
    "tags": [
      "freelang-v2",
      "level-3-complete",
      "production-ready",
      "float-support",
      "tcp-network",
      "jit-hotspot",
      "aot-compile",
      "llvm-optimization"
    ],
    "entry": "dist/cli/index.js",
    "cli": true,
    "version": "2.9.0",
    "status": "production-ready",
    "level": 3,
    "completeness": "100%",
    "dependencies": [],
    "exports": {
      "cli": "./dist/cli/index.js",
      "engine": "./dist/engine/auto-header.js",
      "parser": "./dist/parser/parser.js",
      "vm": "./dist/vm/vm-executor.js",
      "optimizer": "./dist/phase-14-llvm/llvm-optimizer.js"
    }
  }
}
